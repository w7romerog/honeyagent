# infra/secrets_manager.tf.disabled_stub
#
# Documenta cómo se extendería el patrón al honeypot type=secrets_manager
# (hp-prod-db-password en honeypots.yaml, enabled: false).
#
# Este archivo NO termina en ".tf": Terraform lo ignora por completo, así que
# no se aprovisiona ningún recurso real. Para habilitarlo en un trabajo
# futuro: renombrar a "secrets_manager.tf", pasar `enabled: true` en
# honeypots.yaml, y agregar una regla de EventBridge que matchee
# `eventSource = secretsmanager.amazonaws.com` sobre `requestParameters.secretId`.
# El pipeline de detección y el agente no cambian.

locals {
  secrets_manager_honeypots = {
    for hp in local.all_honeypots : hp.name => hp
    if hp.type == "secrets_manager" && hp.enabled
  }
}

resource "aws_secretsmanager_secret" "honeypot_secret" {
  for_each = local.secrets_manager_honeypots

  name                    = each.value.name
  description             = lookup(each.value.config, "description", each.value.description)
  recovery_window_in_days = 0

  tags = { HoneyAgent = "true", Purpose = "honeypot" }
}

resource "aws_secretsmanager_secret_version" "honeypot_secret" {
  for_each = local.secrets_manager_honeypots

  secret_id     = aws_secretsmanager_secret.honeypot_secret[each.key].id
  secret_string = each.value.config.secret_value
}
