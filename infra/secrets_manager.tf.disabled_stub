# Stub del honeypot Secrets Manager (enabled: false). No termina en .tf:
# Terraform lo ignora. Para habilitarlo: renombrar a secrets_manager.tf,
# enabled: true, y agregar la regla de EventBridge correspondiente.

locals {
  secrets_manager_honeypots = {
    for hp in local.all_honeypots : hp.name => hp
    if hp.type == "secrets_manager" && hp.enabled
  }
}

resource "aws_secretsmanager_secret" "honeypot_secret" {
  for_each = local.secrets_manager_honeypots

  name                    = each.value.name
  description             = lookup(each.value.config, "description", each.value.description)
  recovery_window_in_days = 0

  tags = { HoneyAgent = "true", Purpose = "honeypot" }
}

resource "aws_secretsmanager_secret_version" "honeypot_secret" {
  for_each = local.secrets_manager_honeypots

  secret_id     = aws_secretsmanager_secret.honeypot_secret[each.key].id
  secret_string = each.value.config.secret_value
}
