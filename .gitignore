# ── Secretos y configuración local ─────────────────────────────────────────────
# NUNCA commitear estos archivos: contienen credenciales reales
.env
.env.local
.env.production
.env.staging
# .env.example SÍ se versiona (es el template sin valores reales)

# Secretos de AWS
*.pem
*.key
credentials
aws_credentials

# ── Python ──────────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python
*.egg-info/
dist/
build/
.eggs/
*.egg
pip-log.txt

# Entornos virtuales
.venv/
venv/
env/
ENV/
.python-version

# Cache de pytest y Python
.pytest_cache/

# ── Terraform ───────────────────────────────────────────────────────────────────
# State local puede contener ARNs, IDs de recursos y otros datos sensibles.
# infra/.terraform.lock.hcl SÍ se versiona (recomendado por Terraform para
# reproducibilidad de versiones de provider).
infra/.terraform/
infra/terraform.tfstate
infra/terraform.tfstate.backup
infra/tfplan.out
# ZIP generado por scripts/build_lambda_package.sh
infra/lambda_package.zip
# Pueden contener valores reales; usar variables de entorno en su lugar
*.tfvars
# Los templates de tfvars sí se versionan
!*.tfvars.example

# ── Reportes generados ──────────────────────────────────────────────────────────
# Los reportes pueden contener IPs, usuarios y datos del incidente
reports/
*.pdf
*.json
# Los eventos de test sí se versionan
!tests/mock_events/*.json

# ── IDEs y sistema operativo ────────────────────────────────────────────────────
.idea/
.vscode/
*.swp
*.swo
.DS_Store
Thumbs.db

# ── Logs ────────────────────────────────────────────────────────────────────────
*.log
logs/
