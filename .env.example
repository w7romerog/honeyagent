# .env.example
# Template de variables de entorno para desarrollo local.
# Copiar a .env y completar con valores reales.
# NUNCA commitear el archivo .env al repositorio.

# ── Claude API ─────────────────────────────────────────────────────────────────
# Obtener en: https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-...

# ── AWS ────────────────────────────────────────────────────────────────────────
# Credenciales de la cuenta de laboratorio
AWS_ACCESS_KEY_ID=AKIA...
AWS_SECRET_ACCESS_KEY=...
AWS_REGION=us-east-1

# ── Slack (solo para desarrollo local) ─────────────────────────────────────────
# En producción este valor vive en Secrets Manager, no aquí.
# Formato: https://hooks.slack.com/services/T.../B.../...
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/...

# ── AbuseIPDB ──────────────────────────────────────────────────────────────────
# Free tier: 1000 checks/día. Registrar en https://www.abuseipdb.com/
ABUSEIPDB_API_KEY=...

# ── Configuración del agente ───────────────────────────────────────────────────
# Nombre del secret en Secrets Manager (usado en producción/Lambda)
SLACK_WEBHOOK_SECRET=honeyagent/slack/webhook

# Modelo Claude a usar (haiku para tests rápidos, sonnet para análisis completo)
AGENT_MODEL=claude-sonnet-4-6
