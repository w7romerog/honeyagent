# .env.example
# Template de variables de entorno para desarrollo local.
# Copiar a .env y completar con valores reales.
# NUNCA commitear el archivo .env al repositorio.

# ── AWS ────────────────────────────────────────────────────────────────────────
# Credenciales del operador (cuenta de laboratorio) — usadas por Terraform, por
# scripts/simulate_attack.py (lee las credenciales señuelo de Secrets Manager),
# y por el agente para invocar Claude vía Amazon Bedrock (sin API key de
# Anthropic: usa estas mismas credenciales/rol de IAM).
AWS_ACCESS_KEY_ID=AKIA...
AWS_SECRET_ACCESS_KEY=...
AWS_REGION=us-east-1

# ── Configuración del agente ───────────────────────────────────────────────────
# ID de modelo en Amazon Bedrock (inference profile). Los modelos Haiku son más
# económicos pero requieren completar un formulario de "intended use case" en
# la consola de Bedrock antes de poder invocarse; Sonnet 4.5 funciona sin ese
# trámite y su costo es marginal para el volumen de este MVP (ver
# agent.model_env_var en honeypots.yaml).
AGENT_MODEL=us.anthropic.claude-sonnet-4-5-20250929-v1:0

# Bucket S3 destino de los reportes .md/.json (creado por infra/main.tf; el
# nombre exacto lo da el output `reports_bucket` después de `terraform apply`).
# Solo hace falta si vas a correr `python -m agent.lambda_handler` en local
# contra el bucket real. No es necesario para pytest -m unit (ese path se
# mockea explícitamente en los tests) ni para scripts/simulate_attack.py.
REPORT_BUCKET=honeyagent-reports-...
